{
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Document title"
    },
    "author": {
      "type": "string",
      "description": "Document author or issuing organization"
    },
    "created_date": {
      "type": "string",
      "description": "Document creation, publication, or announcement date"
    },
    "summary": {
      "type": "string",
      "description": "Short summary of the document"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Important keywords found in the document"
    },
    "toc": {
      "type": "array",
      "description": "Table of contents or major section headings",
      "items": {
        "type": "object",
        "properties": {
          "level": {
            "type": "integer",
            "description": "Heading depth level, starting from 1"
          },
          "title": {
            "type": "string"
          }
        },
        "required": [
          "level",
          "title"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "title",
    "author",
    "created_date",
    "summary",
    "keywords",
    "toc"
  ],
  "additionalProperties": false
}
